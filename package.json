{
  "name": "yuyeyyy-graphics-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "index": "pagefind --site out",
    "cf:dev": "wrangler pages dev",
    "cf:deploy": "node scripts/export-d1-posts.mjs && npm run build && npm run index && wrangler pages deploy out",
    "db:export": "node scripts/export-d1-posts.mjs",
    "db:import": "node scripts/import-posts-to-d1.mjs",
    "db:init": "wrangler d1 execute yuyepage-db --file=migrations/0001_init.sql",
    "db:local": "wrangler d1 execute yuyepage-db --local --file=migrations/0001_init.sql",
    "db:query": "wrangler d1 execute yuyepage-db --command"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "feed": "^5.2.1",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "mdast-util-toc": "^7.1.0",
    "next": "^15.1.6",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/three": "^0.185.0",
    "eslint": "^9",
    "eslint-config-next": "^15.1.6",
    "pagefind": "^1.5.2",
    "postcss": "^8.4.49",
    "prettier": "^3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.107.0"
  }
}
