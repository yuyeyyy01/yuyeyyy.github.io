# 本地开发环境变量 —— 复制为 .dev.vars（wrangler pages dev 会加载）
# .dev.vars 不要提交（已在 .gitignore）

# 管理后台口令（你一人用，起个强口令）
ADMIN_TOKEN=换成你自己的强口令

# 站点 basePath：根路径部署留空，GitHub Pages 子路径用 /yuyeyyy.github.io
NEXT_PUBLIC_BASE_PATH=

# 站点根 URL（SEO/RSS/OG 用）
NEXT_PUBLIC_SITE_URL=https://你的域名.pages.dev

# Cloudflare Pages Deploy Hook URL（PR4 自动重建 + 图片上传后触发，先留空）
DEPLOY_HOOK_URL=

# 图片上传到 GitHub 仓库（后台拖拽/粘贴图片用，不绑卡不用 R2）
# GITHUB_TOKEN：PAT，只需目标仓库 contents:write 权限
# GITHUB_REPO：仓库全名（可省，默认 yuyeyyy01/yuyeyyy.github.io）
# GITHUB_BRANCH：提交分支（可省，默认 main）
GITHUB_TOKEN=
GITHUB_REPO=yuyeyyy01/yuyeyyy.github.io
GITHUB_BRANCH=main
