# 本地开发环境变量 —— 复制为 .dev.vars（wrangler pages dev 会加载）
# .dev.vars 不要提交（已在 .gitignore）

# 管理后台口令（你一人用，起个强口令）
ADMIN_TOKEN=换成你自己的强口令

# 站点 basePath：根路径部署留空，GitHub Pages 子路径用 /yuyeyyy.github.io
NEXT_PUBLIC_BASE_PATH=

# 站点根 URL（SEO/RSS/OG 用）
NEXT_PUBLIC_SITE_URL=https://你的域名.pages.dev

# 自动重建用：后台保存文章后触发 GitHub Actions 重建部署
# GITHUB_TOKEN：GitHub PAT（repo 权限），Functions 调 repository_dispatch API 用
# GITHUB_REPO：目标仓库全名（可省，默认 yuyeyyy01/yuyeyyy.github.io）
GITHUB_TOKEN=
GITHUB_REPO=yuyeyyy01/yuyeyyy.github.io
